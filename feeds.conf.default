# ImmortalWrt H5000M 软件源配置

# 核心官方源
src-git packages https://github.com/immortalwrt/packages.git;openwrt-24.10
src-git luci https://github.com/immortalwrt/luci.git;openwrt-24.10
src-git routing https://github.com/openwrt/routing.git;openwrt-24.10
src-git telephony https://github.com/openwrt/telephony.git;openwrt-24.10

# 可选第三方源
src-git qmodem https://github.com/FUjr/QModem.git;main
src-git nikki https://github.com/nikkinikki-org/OpenWrt-nikki.git;main

# RU - Zapret - Netshift
src-git zapret https://github.com/remittor/zapret-openwrt.git;zap1
src-git netshift https://github.com/yandexru45/netshift.git

# Modem Web UI
src-git modemwebui https://github.com/lonelysix-editor/luci-app-modemwebui.git
